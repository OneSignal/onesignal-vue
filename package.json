  "devDependencies": {
    "typescript": "^6.0.3",
    "vite-plus": "0.1.21"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "onesignal",
    "push",
    "notification",
    "push notification",
    "vue"
  ],
  "packageManager": "bun@1.3.13"
